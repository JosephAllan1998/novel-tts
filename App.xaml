<Application x:Class="novel_tts.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:novel_tts"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Light.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignColors;component/Themes/Recommended/Primary/MaterialDesignColor.DeepPurple.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignColors;component/Themes/Recommended/Accent/MaterialDesignColor.Lime.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="TextBlockBaseStyle">
                <Setter Property="TextBlock.FontFamily" Value="SegoeUI" />
            </Style>

            <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource TextBlockBaseStyle}"></Style>


            <Style BasedOn="{StaticResource MaterialDesignRaisedButton}" TargetType="{x:Type Button}" >
                <Setter Property="Height" Value="Auto"></Setter>
            </Style>

            <Style x:Key="mainColorStyle">
                <Setter Property="Grid.Background" Value="Transparent"/>
            </Style>

            <Style x:Key="headerSupportPopUpStyle">
                <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                <Setter Property="TextBlock.TextAlignment" Value="Center" />
                <Setter Property="TextBlock.FontWeight" Value="Bold" />
                <Setter Property="TextBlock.FontSize" Value="25" />
                <Setter Property="TextBlock.FontFamily" Value="Noto Sans Cond Med" />
                <Setter Property="TextBlock.Foreground" Value="#666666" />
            </Style>

            <Style x:Key="thankUsing">
                <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                <Setter Property="TextBlock.TextAlignment" Value="Center" />
                <Setter Property="TextBlock.FontWeight" Value="Bold" />
                <Setter Property="TextBlock.FontSize" Value="35" />
                <Setter Property="TextBlock.FontFamily" Value="Microsoft YaHei UI" />
                <Setter Property="TextBlock.Foreground" Value="#666666" />
            </Style>


            <Style x:Key="BlockButtonTextStyle">
                <Setter Property="TextBlock.Foreground" Value="Black"/>
                <Setter Property="TextBlock.TextWrapping" Value="Wrap"/>
                <Setter Property="TextBlock.Padding" Value="0 22"/>
                <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                <Setter Property="TextBlock.FontSize" Value="27"/>
                <Setter Property="TextBlock.FontWeight" Value="SemiBold"/>
                <Setter Property="TextBlock.FontFamily" Value="Microsoft YaHei UI" />
            </Style>

            <Style x:Key="touchToGoHome">
                <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                <Setter Property="TextBlock.TextAlignment" Value="Center" />
                <Setter Property="TextBlock.FontWeight" Value="Bold" />
                <Setter Property="TextBlock.FontSize" Value="35" />
                <Setter Property="TextBlock.FontFamily" Value="Microsoft YaHei UI" />
                <Setter Property="TextBlock.Foreground" Value="#666666" />
            </Style>
            <!--message for login admin and management-->
            <Style x:Key="CPIBTextboxStyle">
                <Setter Property="TextBox.Foreground" Value="Red" />
                <Setter Property="TextBox.BorderThickness" Value="0" />
                <Setter Property="TextBox.Background" Value="#F3F3F3" />
                <Setter Property="TextBox.Height" Value="65" />
                <Setter Property="TextBox.Width" Value="600" />
                <Setter Property="TextBox.FontSize" Value="24" />
                <Setter Property="TextBlock.FontFamily" Value="Noto Sans Cond Med" />
            </Style>

            <Style x:Key="PopupButtonStyle">
                <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                <Setter Property="TextBlock.TextAlignment" Value="Center" />
                <Setter Property="TextBlock.FontWeight" Value="Bold" />
                <Setter Property="TextBlock.FontSize" Value="27" />
                <Setter Property="TextBlock.FontFamily" Value="Microsoft YaHei UI" />
                <Setter Property="TextBlock.Foreground" Value="#666666" />
                <Setter Property="Button.BorderBrush" Value="Transparent" />
                <Setter Property="Button.Foreground" Value="Black" />
                <Setter Property="Button.Background" Value="Transparent" />
            </Style>

            <!--Locker Diagram Style-->
            <Style x:Key="LockerOpenStyle" TargetType="Border">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Path=ColorFormat}" Value="True">
                        <Setter Property="Background" Value="#92D050"/>
                    </DataTrigger>

                    <DataTrigger Binding="{Binding Path=ColorFormat}" Value="False">
                        <Setter Property="Background" Value="#BFBFBF"/>
                        <Setter Property="BorderBrush" Value="#B6B6B6"/>
                    </DataTrigger>

                </Style.Triggers>
            </Style>

            <Style x:Key="headerPackInfoDetailStyle">
                <Setter Property="TextBlock.TextAlignment" Value="Left" />
                <Setter Property="TextBlock.FontSize" Value="20" />
                <Setter Property="TextBlock.FontFamily" Value="Noto Sans Cond Med" />
                <Setter Property="TextBlock.Foreground" Value="#666666" />
            </Style>

            <Style x:Key="headerPackInfoStyle">
                <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                <Setter Property="TextBlock.TextAlignment" Value="Center" />
                <Setter Property="TextBlock.FontWeight" Value="Bold" />
                <Setter Property="TextBlock.FontSize" Value="22" />
                <Setter Property="TextBlock.FontFamily" Value="Noto Sans Cond Med" />
                <Setter Property="TextBlock.Foreground" Value="#666666" />
            </Style>

            <Style x:Key="LockerOpenTextStyle" TargetType="TextBlock">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Path=ColorFormat}" Value="True">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontFamily" Value="Open Sans SemiBold" />
                        <Setter Property="FontSize" Value="25" />

                    </DataTrigger>

                    <DataTrigger Binding="{Binding Path=ColorFormat}" Value="False">
                        <Setter Property="FontFamily" Value="Open Sans SemiBold" />
                        <Setter Property="FontSize" Value="25" />
                    </DataTrigger>

                    <DataTrigger Binding="{Binding Path=name}" Value="">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>

                </Style.Triggers>
            </Style>

            <!--all header page-->
            <Style x:Key="headerStyle">
                <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                <Setter Property="TextBlock.VerticalAlignment" Value="Center" />
                <Setter Property="TextBlock.TextAlignment" Value="Center" />
                <Setter Property="TextBlock.FontWeight" Value="Bold" />
                <Setter Property="TextBlock.FontSize" Value="42" />
                <Setter Property="TextBlock.FontFamily" Value="Noto Sans Cond Med" />
                <Setter Property="TextBlock.Foreground" Value="#120e09" />
            </Style>
            <Style x:Key="textDUration">
                <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                <Setter Property="TextBlock.VerticalAlignment" Value="Center" />
                <Setter Property="TextBlock.TextAlignment" Value="Center" />
                <Setter Property="TextBlock.FontWeight" Value="Bold" />
                <Setter Property="TextBlock.FontSize" Value="40" />
                <Setter Property="TextBlock.FontFamily" Value="Noto Sans Cond Med" />
                <Setter Property="TextBlock.Foreground" Value="#707070" />
            </Style>
            <!--button store and retrieve-->
            <Style x:Key="storeAndretrieveStyle">
                <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                <Setter Property="TextBlock.TextAlignment" Value="Center" />
                <Setter Property="TextBlock.FontWeight" Value="Bold" />
                <Setter Property="TextBlock.FontSize" Value="60" />
                <Setter Property="TextBlock.FontFamily" Value="Noto Sans Cond Med" />
                <Setter Property="TextBlock.Foreground" Value="#000000" />
            </Style>

            <Style x:Key="buttonTextStyle">
                <Setter Property="TextBlock.TextWrapping" Value="Wrap"/>
                <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                <Setter Property="TextBlock.VerticalAlignment" Value="Center"/>
                <Setter Property="TextBlock.HorizontalAlignment" Value="Center"/>
                <Setter Property="TextBlock.FontSize" Value="28"/>
                <Setter Property="TextBlock.FontWeight" Value="Normal"/>
                <Setter Property="TextBlock.FontWeight" Value="SemiBold"/>
                <Setter Property="TextBlock.FontFamily" Value="Noto Sans Cond Med" />
            </Style>

            <Style x:Key="buttonLockerTypeTextStyle">
                <Setter Property="TextBlock.Foreground" Value="Black"/>
                <Setter Property="TextBlock.TextWrapping" Value="Wrap"/>
                <Setter Property="TextBlock.Padding" Value="0 10 0 10"/>
                <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                <Setter Property="TextBlock.FontSize" Value="43"/>
                <Setter Property="TextBlock.FontWeight" Value="Bold"/>
                <Setter Property="TextBlock.FontFamily" Value="Noto Sans Cond Med" />
                <Setter Property="TextBlock.Foreground" Value="#362205" />
            </Style>
            <!--button style main window flow using locker-->
            <Style x:Key="bottomTextStyle">
                <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                <Setter Property="TextBlock.TextAlignment" Value="Center" />
                <Setter Property="TextBlock.FontWeight" Value="Bold" />
                <Setter Property="TextBlock.FontSize" Value="16" />
                <Setter Property="TextBlock.FontFamily" Value="Noto Sans Cond Med" />
                <Setter Property="TextBlock.Padding" Value="0" />
            </Style>
            <!--Border in home flow-->
            <Style x:Key="BorderHome" TargetType="Border">
                <Setter Property="BorderBrush" Value="Black" />
                <Setter Property="BorderThickness" Value="3" />
                <Setter Property="Border.Background" Value="#95FFFFFF"/>
                <Setter Property="CornerRadius" Value="40" />
                <Setter Property="Width" Value="350" />
                <Setter Property="Height" Value="125" />
            </Style>
            <!--border for locker type button-->
            <Style x:Key="BorderLockerType" TargetType="Border">
                <Setter Property="CornerRadius" Value="30"/>
                <Setter Property="BorderBrush" Value="Black"/>
                <Setter Property="BorderThickness" Value="3"/>
                <Setter Property="Background" Value="Transparent"/>
            </Style>

            <!--key in style-->
            <Style x:Key="txtEmailTextStyle">
                <Setter Property="TextBlock.Foreground" Value="Black"/>
                <Setter Property="TextBlock.TextWrapping" Value="Wrap"/>
                <Setter Property="TextBlock.Padding" Value="0 10 0 10"/>
                <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                <Setter Property="TextBlock.FontSize" Value="18"/>
                <Setter Property="TextBlock.FontWeight" Value="Bold"/>
                <Setter Property="TextBlock.FontFamily" Value="Noto Sans Cond Med" />
                <Setter Property="TextBlock.Foreground" Value="#666666" />
            </Style>

            <!--border for email TextBox-->
            <Style x:Key="BorderEmailTextBox" TargetType="Border">
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="BorderBrush" Value="Black"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Background" Value="White"/>
            </Style>

            <!--combobox for email-->
            <Style x:Key="CPIBLableStyle">
                <Setter Property="TextBox.Foreground" Value="#A6A6A6" />
                <Setter Property="TextBox.Padding" Value="20 9 20 0" />
                <Setter Property="TextBox.BorderThickness" Value="0" />
                <Setter Property="TextBox.Background" Value="#F2F2F2" />
                <Setter Property="TextBox.Height" Value="50" />
                <Setter Property="TextBox.FontSize" Value="22" />
                <Setter Property="TextBlock.FontFamily" Value="Open Sans" />
            </Style>

            <Style x:Key="EmailTextBoxStyle" TargetType="TextBox">
                <Setter Property="TextBlock.Foreground" Value="Black"/>
                <Setter Property="TextBlock.TextAlignment" Value="Left"/>
                <Setter Property="TextBlock.FontSize" Value="18"/>
                <Setter Property="TextBlock.FontFamily" Value="Noto Sans Cond Med" />
                <Setter Property="TextBlock.Foreground" Value="#666666"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>

            <Style x:Key="EmailDomainTextBoxStyle" TargetType="ComboBox">
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontFamily" Value="Noto Sans Cond Med"/>
            </Style>

            <!--Thank you Style-->
            <Style x:Key="thankyouStyle">
                <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                <Setter Property="TextBlock.Margin" Value="0 10 0 5"/>
                <Setter Property="TextBlock.TextAlignment" Value="Center" />
                <Setter Property="TextBlock.FontWeight" Value="Bold" />
                <Setter Property="TextBlock.FontSize" Value="40" />
                <Setter Property="TextBlock.FontFamily" Value="Noto Sans Cond Med" />
                <Setter Property="TextBlock.Foreground" Value="#084e99" />
            </Style>

            <!--Package infomation block-->
            <Style x:Key="spAdminPageMenu" TargetType="StackPanel">
                <Setter Property="Margin" Value="30 0 30 0"/>
                <Setter Property="Visibility" Value="Visible"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
            </Style>

            <!--Popup Text-->
            <Style x:Key="popupTextStyle">
                <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                <Setter Property="TextBlock.Margin" Value="0 10 0 5"/>
                <Setter Property="TextBlock.TextAlignment" Value="Center" />
                <Setter Property="TextBlock.FontWeight" Value="Bold" />
                <Setter Property="TextBlock.FontSize" Value="30" />
                <Setter Property="TextBlock.FontFamily" Value="Noto Sans Cond Med" />
                <Setter Property="TextBlock.Foreground" Value="#120e09" />
            </Style>

            <!--Popup information-->
            <Style x:Key="popupInfoHeaderStyle">
                <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                <Setter Property="TextBlock.TextAlignment" Value="Center" />
                <Setter Property="TextBlock.FontWeight" Value="Bold" />
                <Setter Property="TextBlock.FontSize" Value="30" />
                <Setter Property="TextBlock.FontFamily" Value="Noto Sans Cond Med" />
                <Setter Property="TextBlock.Foreground" Value="#120e09" />
            </Style>

            <Style x:Key="popupInfoLeftTextStyle">
                <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                <Setter Property="TextBlock.TextAlignment" Value="Left" />
                <Setter Property="TextBlock.FontWeight" Value="DemiBold" />
                <Setter Property="TextBlock.FontSize" Value="26" />
                <Setter Property="TextBlock.FontFamily" Value="Noto Sans Cond Med" />
                <Setter Property="TextBlock.Foreground" Value="#120e09" />
                <Setter Property="TextBlock.Height" Value="40" />
            </Style>

            <Style x:Key="popupInfoRightTextStyle">
                <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                <Setter Property="TextBlock.TextAlignment" Value="Right" />
                <Setter Property="TextBlock.FontWeight" Value="DemiBold" />
                <Setter Property="TextBlock.FontSize" Value="26" />
                <Setter Property="TextBlock.FontFamily" Value="Noto Sans Cond Med" />
                <Setter Property="TextBlock.Foreground" Value="#120e09" />
                <Setter Property="TextBlock.Height" Value="40" />
            </Style>

            <!--lable console admin-->
            <Style x:Key="labelWhiteTextStyle">
                <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                <Setter Property="TextBlock.TextAlignment" Value="Center" />
                <Setter Property="TextBlock.FontSize" Value="15" />
                <Setter Property="TextBlock.Foreground" Value="White"/>
                <Setter Property="TextBlock.FontFamily" Value="Noto Sans Cond Med" />
            </Style>

            <Style x:Key="labelBlackTextStyle">
                <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                <Setter Property="TextBlock.TextAlignment" Value="Center" />
                <Setter Property="TextBlock.FontSize" Value="15" />
                <Setter Property="TextBlock.Foreground" Value="Black"/>
                <Setter Property="TextBlock.FontFamily" Value="Noto Sans Cond Med" />
            </Style>
            <!--more sevice text-->
            <Style x:Key="labelMoreservice">
                <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                <Setter Property="TextBlock.TextAlignment" Value="Center" />
                <Setter Property="TextBlock.FontSize" Value="40" />
                <Setter Property="TextBlock.Padding" Value="5 20 5 20"/>
                <Setter Property="TextBlock.FontWeight" Value="Bold" />
                <Setter Property="TextBlock.Foreground" Value="#362205"/>
                <Setter Property="TextBlock.FontFamily" Value="Noto Sans Cond Med" />
            </Style>
            <!--border for all button-->
            <Style x:Key="BorderButtonStyle" TargetType="Border">
                <Setter Property="Border.Background" Value="#0064a8"/>
                <Setter Property="CornerRadius" Value="15"/>
                <Setter Property="Height" Value="50"/>
            </Style>
            <!--Dùng cho nút STORE AND RETRIEVE, SCAN CARD-->
            <Style x:Key="textBlockStyle1">
                <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                <Setter Property="TextBlock.TextAlignment" Value="Center" />
                <Setter Property="TextBlock.FontWeight" Value="Bold" />
                <Setter Property="TextBlock.FontSize" Value="45" />
                <Setter Property="TextBlock.FontFamily" Value="SegoeUI-Bold" />
                <Setter Property="TextBlock.Foreground" Value="#666633" />
            </Style>
            <!--Error text message-->
            <Style x:Key="errorTextStyle">
                <Setter Property="TextBlock.TextAlignment" Value="Center" />
                <Setter Property="TextBlock.FontSize" Value="28" />
                <Setter Property="TextBlock.FontFamily" Value="Noto Sans Cond Med" />
                <Setter Property="TextBlock.Foreground" Value="Red" />
            </Style>
            <!--Scrollbar Thumbs-->
            <Style x:Key="ScrollThumbs" TargetType="{x:Type Thumb}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Thumb}">
                            <Grid x:Name="Grid">
                                <Rectangle HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Width="Auto" Height="Auto" Fill="Transparent" />
                                <Border x:Name="Rectangle1" CornerRadius="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Width="Auto" Height="Auto" Background="{TemplateBinding Background}" />
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="Tag" Value="Horizontal">
                                    <Setter TargetName="Rectangle1" Property="Width" Value="Auto" />
                                    <Setter TargetName="Rectangle1" Property="Height" Value="7" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <!--ScrollBars-->
            <Style x:Key="{x:Type ScrollBar}" TargetType="{x:Type ScrollBar}">
                <Setter Property="Stylus.IsFlicksEnabled" Value="false" />
                <Setter Property="Foreground" Value="#8C8C8C" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Width" Value="8" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ScrollBar}">
                            <Grid x:Name="GridRoot" Width="8" Background="{TemplateBinding Background}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="0.00001*" />
                                </Grid.RowDefinitions>
                                <Track x:Name="PART_Track" Grid.Row="0" IsDirectionReversed="true" Focusable="false">
                                    <Track.Thumb>
                                        <Thumb x:Name="Thumb" Background="{TemplateBinding Foreground}" Style="{DynamicResource ScrollThumbs}" />
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton x:Name="PageUp" Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="false" />
                                    </Track.IncreaseRepeatButton>
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton x:Name="PageDown" Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="false" />
                                    </Track.DecreaseRepeatButton>
                                </Track>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger SourceName="Thumb" Property="IsMouseOver" Value="true">
                                    <Setter Value="{DynamicResource ButtonSelectBrush}" TargetName="Thumb" Property="Background" />
                                </Trigger>
                                <Trigger SourceName="Thumb" Property="IsDragging" Value="true">
                                    <Setter Value="{DynamicResource DarkBrush}" TargetName="Thumb" Property="Background" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="false">
                                    <Setter TargetName="Thumb" Property="Visibility" Value="Collapsed" />
                                </Trigger>
                                <Trigger Property="Orientation" Value="Horizontal">
                                    <Setter TargetName="GridRoot" Property="LayoutTransform">
                                        <Setter.Value>
                                            <RotateTransform Angle="-90" />
                                        </Setter.Value>
                                    </Setter>
                                    <Setter TargetName="PART_Track" Property="LayoutTransform">
                                        <Setter.Value>
                                            <RotateTransform Angle="-90" />
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Width" Value="Auto" />
                                    <Setter Property="Height" Value="8" />
                                    <Setter TargetName="Thumb" Property="Tag" Value="Horizontal" />
                                    <Setter TargetName="PageDown" Property="Command" Value="ScrollBar.PageLeftCommand" />
                                    <Setter TargetName="PageUp" Property="Command" Value="ScrollBar.PageRightCommand" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
