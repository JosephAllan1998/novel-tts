<Window x:Class="NovelTTS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="NovelTTS – Chuyển Đổi Tiểu Thuyết Sang Audio"
        Width="1050" Height="720"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Window.Resources>
        <!-- ── Color palette ── -->
        <SolidColorBrush x:Key="BgDeep"      Color="#1E1E2E"/>
        <SolidColorBrush x:Key="BgPanel"     Color="#2A2A3E"/>
        <SolidColorBrush x:Key="BgCard"      Color="#313148"/>
        <SolidColorBrush x:Key="AccentBlue"  Color="#7C83FD"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#4ADE80"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#FB923C"/>
        <SolidColorBrush x:Key="AccentRed"   Color="#F87171"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#94A3B8"/>
        <SolidColorBrush x:Key="Border1"     Color="#3D3D5C"/>

        <!-- ── TextBlock default ── -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="13"/>
        </Style>

        <!-- ── Label ── -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Padding"    Value="0,2"/>
        </Style>

        <!-- ── TextBox ── -->
        <Style TargetType="TextBox">
            <Setter Property="Background"           Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground"           Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"          Value="{StaticResource Border1}"/>
            <Setter Property="BorderThickness"      Value="1"/>
            <Setter Property="Padding"              Value="8,6"/>
            <Setter Property="FontFamily"           Value="Segoe UI"/>
            <Setter Property="FontSize"             Value="13"/>
            <Setter Property="CaretBrush"           Value="{StaticResource TextPrimary}"/>
            <Setter Property="SelectionBrush"       Value="{StaticResource AccentBlue}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ── Button Base ── -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="FontFamily"     Value="Segoe UI Semibold"/>
            <Setter Property="FontSize"       Value="13"/>
            <Setter Property="Padding"        Value="14,7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnPrimary"  BasedOn="{StaticResource BtnBase}" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="BtnSuccess"  BasedOn="{StaticResource BtnBase}" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentGreen}"/>
            <Setter Property="Foreground" Value="#111"/>
        </Style>
        <Style x:Key="BtnWarning"  BasedOn="{StaticResource BtnBase}" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentOrange}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="BtnDanger"   BasedOn="{StaticResource BtnBase}" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentRed}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="BtnSecondary" BasedOn="{StaticResource BtnBase}" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <!-- ── ProgressBar ── -->
        <Style TargetType="ProgressBar">
            <Setter Property="Height"      Value="10"/>
            <Setter Property="Foreground"  Value="{StaticResource AccentBlue}"/>
            <Setter Property="Background"  Value="{StaticResource BgCard}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border CornerRadius="5" Background="{TemplateBinding Background}">
                            <Border x:Name="PART_Track">
                                <Border x:Name="PART_Indicator"
                                        Background="{TemplateBinding Foreground}"
                                        CornerRadius="5"
                                        HorizontalAlignment="Left"/>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── TaItem ── -->
        <Style TargetType="TabItem">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="{StaticResource TextMuted}"/>
            <Setter Property="FontFamily"  Value="Segoe UI Semibold"/>
            <Setter Property="FontSize"    Value="14"/>
            <Setter Property="Padding"     Value="18,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="border" Padding="{TemplateBinding Padding}"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── TabControl ── -->
        <Style TargetType="TabControl">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Padding"          Value="0"/>
        </Style>

        <!-- ── ComboBox ── -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"      Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Border1}"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Padding"         Value="8,5"/>
        </Style>

        <!-- ── Slider ── -->
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
        </Style>

        <!-- ── Section header ── -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize"   Value="15"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Margin"     Value="0,0,0,8"/>
        </Style>

        <!-- ── Card border ── -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"     Value="{StaticResource BgPanel}"/>
            <Setter Property="CornerRadius"   Value="10"/>
            <Setter Property="Padding"        Value="16"/>
            <Setter Property="BorderBrush"    Value="{StaticResource Border1}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin"         Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <!-- Title bar -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="32"/>
            <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ Title Bar ═══ -->
        <Border Grid.Row="0" Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource Border1}" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="📖" FontSize="22" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="NovelTTS" FontSize="20" FontFamily="Segoe UI Black"
                               Foreground="{StaticResource AccentBlue}" VerticalAlignment="Center"/>
                    <TextBlock Text=" – Tiểu Thuyết Mạng → Audio" FontSize="14"
                               Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="TxtProjectName" HorizontalAlignment="Right"
                           VerticalAlignment="Center" Margin="0,0,20,0"
                           Foreground="{StaticResource TextMuted}" FontSize="12"/>
            </Grid>
        </Border>

        <!-- ═══ Main TabControl ═══ -->
        <TabControl x:Name="MainTab" Grid.Row="1" Margin="12,8">

            <!-- ─── Tab 1: CRAWLER ─── -->
            <TabItem Header="🕷 Crawler">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="4,8,4,4">

                        <!-- Project info card -->
                        <Border Style="{StaticResource Card}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                           Text="⚙ Cấu Hình Dự Án" Style="{StaticResource SectionHeader}"/>

                                <Label Grid.Row="2" Content="URL Truyện:" VerticalAlignment="Center"/>
                                <Grid Grid.Row="2" Grid.Column="0" Margin="80,0,0,0">
                                    <TextBox x:Name="TxtUrl" Text="https://truyenfull.today/de-ba/" Height="34"/>
                                </Grid>

                                <Label Grid.Row="4" Content="Thư mục lưu:" VerticalAlignment="Center"/>
                                <Grid Grid.Row="4" Grid.Column="0" Margin="80,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtWorkDir" Height="34"
                                             Text="D:\01.Work\02.Personal\novel-tts\bin\novel"/>
                                    <Button Grid.Column="1" Content="📁 Duyệt" Margin="8,0,0,0"
                                            Style="{StaticResource BtnSecondary}"
                                            x:Name="BtnBrowse" Click="BtnBrowse_Click"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Settings card -->
                        <Border Style="{StaticResource Card}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.ColumnSpan="4"
                                           Text="🔧 Cài Đặt Crawler" Style="{StaticResource SectionHeader}"/>

                                <!-- Chapters per merge -->
                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,0">
                                    <Label Content="Chương mỗi file merge:"/>
                                    <TextBox x:Name="TxtChaptersPerMerge" Text="10" Height="34"/>
                                </StackPanel>
                                <!-- Retry -->
                                <StackPanel Grid.Row="2" Grid.Column="1" Margin="4,0,8,0">
                                    <Label Content="Số lần retry:"/>
                                    <TextBox x:Name="TxtRetryCount" Text="4" Height="34"/>
                                </StackPanel>
                                <!-- Delay min -->
                                <StackPanel Grid.Row="2" Grid.Column="2" Margin="4,0,8,0">
                                    <Label Content="Delay tối thiểu (ms):"/>
                                    <TextBox x:Name="TxtMinDelay" Text="800" Height="34"/>
                                </StackPanel>
                                <!-- Delay max -->
                                <StackPanel Grid.Row="2" Grid.Column="3" Margin="4,0,0,0">
                                    <Label Content="Delay tối đa (ms):"/>
                                    <TextBox x:Name="TxtMaxDelay" Text="2500" Height="34"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Controls card -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="▶ Điều Khiển Pipeline" Style="{StaticResource SectionHeader}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <Button x:Name="BtnStart"  Content="▶ Bắt Đầu" Style="{StaticResource BtnPrimary}"
                                            Margin="0,0,8,0" Click="BtnStart_Click"/>
                                    <Button x:Name="BtnPause"  Content="⏸ Tạm Dừng" Style="{StaticResource BtnWarning}"
                                            Margin="0,0,8,0" Click="BtnPause_Click" IsEnabled="False"/>
                                    <Button x:Name="BtnResume" Content="▶ Tiếp Tục" Style="{StaticResource BtnSuccess}"
                                            Margin="0,0,8,0" Click="BtnResume_Click" IsEnabled="False"/>
                                    <Button x:Name="BtnStop"   Content="⏹ Dừng"    Style="{StaticResource BtnDanger}"
                                            Click="BtnStop_Click" IsEnabled="False"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Progress card -->
                        <Border Style="{StaticResource Card}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition/>
                                    <RowDefinition Height="4"/>
                                    <RowDefinition/>
                                    <RowDefinition Height="4"/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="📊 Tiến Độ" Style="{StaticResource SectionHeader}"/>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Danh sách chương:" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                    <ProgressBar x:Name="PbCrawl" Grid.Column="1" Value="0" Maximum="100" Margin="8,0"/>
                                    <TextBlock x:Name="TxtCrawlPct" Grid.Column="2" Text="0" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>

                                <Grid Grid.Row="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Download HTML:" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                    <ProgressBar x:Name="PbDownload" Grid.Column="1" Value="0" Maximum="100" Margin="8,0"
                                                 Foreground="{StaticResource AccentGreen}"/>
                                    <TextBlock x:Name="TxtDownloadPct" Grid.Column="2" Text="0" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>

                                <Grid Grid.Row="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Parse → TXT:" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                    <ProgressBar x:Name="PbParse" Grid.Column="1" Value="0" Maximum="100" Margin="8,0"
                                                 Foreground="{StaticResource AccentOrange}"/>
                                    <TextBlock x:Name="TxtParsePct" Grid.Column="2" Text="0" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Log card -->
                        <Border Style="{StaticResource Card}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="200"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <TextBlock Text="📋 Log" Style="{StaticResource SectionHeader}"/>
                                    <Button Content="Xoá" HorizontalAlignment="Right"
                                            Style="{StaticResource BtnSecondary}" Padding="12,4"
                                            x:Name="BtnClearCrawlLog" Click="BtnClearCrawlLog_Click"/>
                                </Grid>
                                <TextBox Grid.Row="1" x:Name="TxtCrawlLog"
                                         IsReadOnly="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         FontFamily="Consolas" FontSize="11"
                                         Background="{StaticResource BgDeep}"
                                         Foreground="#A0E0A0"
                                         BorderThickness="0"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ─── Tab 2: MERGE & TTS ─── -->
            <TabItem Header="🎙 Merge &amp; TTS">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="4,8,4,4">

                        <!-- Merge config card -->
                        <Border Style="{StaticResource Card}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                           Text="📦 Cấu Hình Merge" Style="{StaticResource SectionHeader}"/>

                                <Label Grid.Row="2" Content="Số chương mỗi file merge:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtMergeCount"
                                         Text="10" Width="80" Height="34" HorizontalAlignment="Left"/>

                                <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal">
                                    <Button x:Name="BtnRunMerge" Content="⚙ Chạy Merge"
                                            Style="{StaticResource BtnPrimary}"
                                            Margin="0,0,8,0" Click="BtnRunMerge_Click"/>
                                    <Button x:Name="BtnCancelMerge" Content="✕ Huỷ"
                                            Style="{StaticResource BtnDanger}"
                                            IsEnabled="False" Click="BtnCancelMerge_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Merge progress card -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="📊 Tiến Độ Merge" Style="{StaticResource SectionHeader}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <ProgressBar x:Name="PbMerge" Height="14" Value="0" Maximum="100"
                                                 Foreground="{StaticResource AccentOrange}"/>
                                    <TextBlock x:Name="TxtMergeStatus" Grid.Column="1" Margin="12,0,0,0"
                                               Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"
                                               Text="0 / 0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- TTS config card -->
                        <Border Style="{StaticResource Card}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                           Text="🔊 Cài Đặt TTS (Text-to-Speech)" Style="{StaticResource SectionHeader}"/>

                                <Label   Grid.Row="2" Content="Giọng đọc:" VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="CboVoice" Height="34"/>

                                <Label   Grid.Row="4" Content="Tốc độ đọc (-10 → 10):" VerticalAlignment="Center"/>
                                <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
                                    <Slider x:Name="SliderRate" Width="200" Minimum="-10" Maximum="10" Value="0"
                                            TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtRateVal" Margin="10,0,0,0" VerticalAlignment="Center"
                                               Text="0" Foreground="{StaticResource AccentBlue}"/>
                                </StackPanel>

                                <Label   Grid.Row="6" Content="Số threads TTS (1–5):" VerticalAlignment="Center"/>
                                <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal">
                                    <Slider x:Name="SliderTtsThreads" Width="150" Minimum="1" Maximum="5" Value="2"
                                            TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtTtsThreadsVal" Margin="10,0,0,0" VerticalAlignment="Center"
                                               Text="2" Foreground="{StaticResource AccentGreen}"/>
                                </StackPanel>

                                <Label   Grid.Row="8" Content="Định dạng output:" Grid.ColumnSpan="1" VerticalAlignment="Center"/>
                                <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal">
                                    <RadioButton x:Name="RbMp3" Content="MP3" IsChecked="True"
                                                 Foreground="{StaticResource TextPrimary}" Margin="0,0,20,0"
                                                 VerticalAlignment="Center"/>
                                    <RadioButton x:Name="RbWav" Content="WAV"
                                                 Foreground="{StaticResource TextPrimary}"
                                                 VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- TTS controls -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="▶ Điều Khiển TTS" Style="{StaticResource SectionHeader}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <Button x:Name="BtnRunTts"    Content="▶ Chạy TTS"    Style="{StaticResource BtnPrimary}"   Margin="0,0,8,0" Click="BtnRunTts_Click"/>
                                    <Button x:Name="BtnPauseTts"  Content="⏸ Tạm Dừng"   Style="{StaticResource BtnWarning}"   Margin="0,0,8,0" IsEnabled="False" Click="BtnPauseTts_Click"/>
                                    <Button x:Name="BtnResumeTts" Content="▶ Tiếp Tục"    Style="{StaticResource BtnSuccess}"   Margin="0,0,8,0" IsEnabled="False" Click="BtnResumeTts_Click"/>
                                    <Button x:Name="BtnStopTts"   Content="⏹ Dừng"        Style="{StaticResource BtnDanger}"                     IsEnabled="False" Click="BtnStopTts_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- TTS progress card -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="📊 Tiến Độ TTS" Style="{StaticResource SectionHeader}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <ProgressBar x:Name="PbTts" Height="14" Value="0" Maximum="100"
                                                 Foreground="{StaticResource AccentGreen}"/>
                                    <TextBlock x:Name="TxtTtsStatus" Grid.Column="1" Margin="12,0,0,0"
                                               Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"
                                               Text="0 / 0" FontSize="12"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- TTS log -->
                        <Border Style="{StaticResource Card}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="180"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <TextBlock Text="📋 Log Merge/TTS" Style="{StaticResource SectionHeader}"/>
                                    <Button Content="Xoá" HorizontalAlignment="Right"
                                            Style="{StaticResource BtnSecondary}" Padding="12,4"
                                            x:Name="BtnClearTtsLog" Click="BtnClearTtsLog_Click"/>
                                </Grid>
                                <TextBox Grid.Row="1" x:Name="TxtTtsLog"
                                         IsReadOnly="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         FontFamily="Consolas" FontSize="11"
                                         Background="{StaticResource BgDeep}"
                                         Foreground="#A0D0FF"
                                         BorderThickness="0"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ─── Tab 3: LOG FILES ─── -->
            <TabItem Header="📂 Log Files">
                <Grid Margin="4,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="📖 Mở Crawler.log" Style="{StaticResource BtnSecondary}"
                                Margin="0,0,8,0" x:Name="BtnOpenCrawlerLog" Click="BtnOpenLog_Click" Tag="crawler.log"/>
                        <Button Content="📖 Parser.log" Style="{StaticResource BtnSecondary}"
                                Margin="0,0,8,0" x:Name="BtnOpenParserLog" Click="BtnOpenLog_Click" Tag="parser.log"/>
                        <Button Content="📖 Merge.log" Style="{StaticResource BtnSecondary}"
                                Margin="0,0,8,0" x:Name="BtnOpenMergeLog" Click="BtnOpenLog_Click" Tag="merge.log"/>
                        <Button Content="📖 TTS.log" Style="{StaticResource BtnSecondary}"
                                Margin="0,0,8,0" x:Name="BtnOpenTtsLog" Click="BtnOpenLog_Click" Tag="tts.log"/>
                        <Button Content="⚠ Error.log" Style="{StaticResource BtnDanger}"
                                x:Name="BtnOpenErrorLog" Click="BtnOpenLog_Click" Tag="error.log"/>
                    </StackPanel>
                    <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0">
                        <TextBox x:Name="TxtLogViewer"
                                 IsReadOnly="True" TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="11"
                                 Background="{StaticResource BgDeep}"
                                 Foreground="#CCCCCC"
                                 BorderThickness="0"/>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- ═══ Status Bar ═══ -->
        <Border Grid.Row="2" Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource Border1}" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <TextBlock x:Name="TxtStatus" VerticalAlignment="Center"
                           Foreground="{StaticResource AccentGreen}" FontSize="12"
                           Text="✅ Sẵn sàng"/>
                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="{StaticResource TextMuted}" FontSize="11"
                           Text="NovelTTS v1.0 | .NET 4.7.2 | System.Speech + HtmlAgilityPack + Polly"/>
            </Grid>
        </Border>
    </Grid>
</Window>
